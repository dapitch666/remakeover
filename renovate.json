{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "pip_requirements": {
    "fileMatch": ["requirements.*\\.txt$"]
  },
  "packageRules": [
    {
      "description": "Group all pip runtime dependencies",
      "matchManagers": ["pip_requirements"],
      "matchFileNames": ["requirements.txt"],
      "groupName": "pip runtime dependencies",
      "automerge": false
    },
    {
      "description": "Group all pip dev dependencies",
      "matchManagers": ["pip_requirements"],
      "matchFileNames": ["requirements-dev.txt"],
      "groupName": "pip dev dependencies",
      "automerge": true,
      "automergeType": "pr",
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Group all GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "automerge": true,
      "automergeType": "pr",
      "matchUpdateTypes": ["minor", "patch", "digest"]
    },
    {
      "description": "Docker base image updates",
      "matchManagers": ["dockerfile"],
      "groupName": "Docker base image",
      "automerge": false
    }
  ]
}
